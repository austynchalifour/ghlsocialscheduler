# App secret for sessions and encrypting GHL tokens (min 32 characters)
# Generate: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-long-random-secret-string

# Supabase PostgreSQL — Transaction pooler (port 6543, for the running app)
# Copy EXACT host from Supabase Dashboard → Project Settings → Database → Connection string
# Example for us-east-2 projects (yours may use aws-1, not aws-0):
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase PostgreSQL — Session pooler (port 5432, for Prisma migrations)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres"
